<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite"
       verbose="1"
       parallel="false">

    <!-- Allure Listener -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Smoke Execution -->
    <test name="Smoke Tests">

        <!-- Execute only Smoke group -->
        <groups>
            <run>
                <include name="Smoke"/>
            </run>
        </groups>

        <!-- Execute all classes from package -->
        <packages>
            <package name="com.thetestingacademy.tests.OldSuites"/>
        </packages>

    </test>

</suite>