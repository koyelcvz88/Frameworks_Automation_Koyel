<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite"
       verbose="1"
       parallel="false">

    <!-- Allure Listener -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Regression Execution -->
    <test name="Regression Tests">

        <!-- Execute only Regression group -->
        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>

        <!-- Execute all classes from package -->
        <packages>
            <package name="com.thetestingacademy.tests.OldSuites"/>
        </packages>

    </test>

</suite>