<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Sanity Suite"
       verbose="1"
       parallel="false">

    <!-- Allure Listener -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Sanity Execution -->
    <test name="Sanity Tests">

        <!-- Execute only Sanity group -->
        <groups>
            <run>
                <include name="Sanity"/>
            </run>
        </groups>

        <!-- Execute all classes from package -->
        <packages>
            <package name="com.thetestingacademy.tests"/>
        </packages>

    </test>

</suite>